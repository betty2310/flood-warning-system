# ---- MQTT (edge broker) ----
MQTT_BROKER=mosquitto
MQTT_PORT=1883
PUBLISH_INTERVAL=2

# ---- Basin / stations ----
BASIN_ID=red-river
STATIONS=station-01,station-02,station-03

# ---- Storm scenario tuning (sensor simulation) ----
# Major-storm scenario: every station crosses the EMERGENCY threshold (4.0 m),
# staggered downstream so the wave and rising crest stay visible (per-station crest
# `peak` in sensor/sensor.py BASIN: st1~4.8, st2~5.5, st3~6.2 m).
# LOOP_PERIOD: seconds per storm cycle. The downstream wave lag SCALES with this --
#   per-station lag is a FRACTION of the cycle (sensor/sensor.py BASIN: 0 / 0.06 / 0.12),
#   so st1->st2->st3 stays a clean marching wave whether the cycle is 120 s or 300 s.
# PEAK_RAIN: mm/h at the storm plateau. DRAINAGE_K: response rate -- the level tracks
#   rain this fast on the way up and down (fast enough it reaches its peak & holds).
# GUST_*: a slow random walk on the rain so the heavy plateau surges/lulls (not flat).
LOOP_PERIOD=300
PEAK_RAIN=65
DRAINAGE_K=0.25
GUST_MM=10
GUST_VOL=2.2
GUST_REVERT=0.10

# ---- InfluxDB ----
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=navis
INFLUXDB_BUCKET=flood
INFLUXDB_TOKEN=flood-edge-token-please-change
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin123456

# ---- Grafana ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

TB_HOST=
TB_PORT=1883
TB_GATEWAY_TOKEN=

# ---- Alarm thresholds (used by the gateway rule engine) ----
# These are BOOTSTRAP DEFAULTS. They can be tuned remotely at runtime by setting
# matching SHARED ATTRIBUTES on the gateway device in ThingsBoard (or via the TB
# REST API) -- keys: level_warning, level_emergency, rainfall_advisory,
# turbidity_max, ph_min, ph_max. The gateway reads them once on connect and then
# live-applies any change, with no restart. See README section 7.
LEVEL_WARNING=3.0
LEVEL_EMERGENCY=4.0
RAINFALL_ADVISORY=40
TURBIDITY_MAX=100
PH_MIN=6
PH_MAX=9
